{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "Cargo.toml": ".editorconfig, .git*, Cargo.lock",
    "README.md": "LICENSE"
  },
  "cSpell.words": [
    "alertable",
    "bcryptprimitives",
    "bepinex",
    "codegen",
    "dialoguer",
    "handleapi",
    "HINSTANCE",
    "HKLM",
    "idsite",
    "indicatif",
    "izakaya",
    "LASTEXITCODE",
    "libstd",
    "lstrcat",
    "metamystia",
    "minwindef",
    "MSVC",
    "mystia",
    "nologo",
    "ntdll",
    "ntifs",
    "NTSTATUS",
    "outpath",
    "prng",
    "PROCESSENTRY",
    "processthreadsapi",
    "reqwest",
    "resourceex",
    "securitybaseapi",
    "serde",
    "shellapi",
    "SNAPPROCESS",
    "steamapps",
    "steamlocate",
    "subkey",
    "SYNCHAPI",
    "termimad",
    "thiserror",
    "tlhelp",
    "toolhelp",
    "touhou",
    "unparse",
    "upgrader",
    "ureq",
    "vcvarsall",
    "vswhere",
    "winapi",
    "winbase",
    "winhttp",
    "winreg",
    "winres"
  ]
}
